# ─── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# Supabase Dashboard → Settings → Database → Connection string
# Use "Transaction" mode URI (port 6543) for DATABASE_URL (pooler)
# Use "Session" mode URI (port 5432) for DIRECT_URL (direct connection)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# ─── Auth.js ────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=your-secret-here-min-32-chars

# ─── Supabase Storage (media uploads) ──────────────────────────────────────────
# Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# ─── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── Site ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://redandwhitecleaningservices.com
